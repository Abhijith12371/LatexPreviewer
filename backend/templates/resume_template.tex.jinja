% ---- Section heading ----
\newcommand{\ressec}[1]{%
  \vspace{5pt}%
  {\small\scshape\textbf{#1}}\\[-4pt]%
  \noindent\rule{\linewidth}{0.4pt}%
  \vspace{2.5pt}%
}

% ---- Entry header ----
\newcommand{\entryA}[3]{%
  \noindent{\small\textbf{#1}}\hfill{\small\textit{#3}}\\[-3pt]%
  \noindent{\footnotesize\textit{#2}}%
  \vspace{2pt}%
}

